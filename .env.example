DB_USER=postgres
DB_HOST=localhost
DB_NAME=gestion_frais
DB_PASSWORD=
DB_PORT=5432
JWT_SECRET=dev_secret_change_me
# Frontend → API : en développement, laissez cette ligne vide pour utiliser le proxy Vite
# (même origine = http://localhost:5173 → proxy vers Express). Sinon URL absolue de l’API :
# VITE_API_URL=http://localhost:3000
VITE_API_URL=

# Optionnel : cible proxy si l’API n’est pas sur localhost:PORT (.env PORT)
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:3000

# URL de connexion PostgreSQL utilisée par Prisma
# Format : postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gestion_frais?schema=public

# Port du serveur Express (par défaut 3000)
PORT=3000

# Environnement d'exécution : development | production | test
NODE_ENV=development
